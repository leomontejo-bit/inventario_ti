{
    "name": "inventario-it",
    "version": "1.0.0",
    "description": "Sistema de inventario IT",
    "author": "Leandro",
    "$schema": "https://www.schemastore.org/package.json",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "vite build",
        "dev": "vite",
        "dist:win": "electron-builder --win",
        "start": "electron .",
        "dist": "electron-builder --win"
    },
    "devDependencies": {
        "@tailwindcss/vite": "^4.0.0",
        "concurrently": "^9.0.1",
        "electron": "^43.0.0",
        "electron-builder": "^26.15.3",
        "laravel-vite-plugin": "^3.1",
        "tailwindcss": "^4.0.0",
        "vite": "^8.0.0"
    },
    "main": "main.js",
    "build": {
        "appId": "com.inventario.it",
        "productName": "Inventario IT",
        "directories": {
            "output": "dist-electron"
        },
        "files": [
            "main.js",
            "package.json",
            "public/**/*",
            "resources/**/*",
            "dist/**/*"
        ],
        "win": {
            "target": "nsis"
        }
    },
    "dependencies": {
        "alpinejs": "^3.15.12"
    }
}
